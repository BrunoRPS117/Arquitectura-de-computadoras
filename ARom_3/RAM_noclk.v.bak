module RAM_noclk(

    input EN, //Ennable este se encarga de leer si escribe o lee
	input [2:0] Dir,
    input [31:0] DatoE,
    output reg [31:0] Datos
);

//crear una memoria (arreglo bidimensional)

reg [31:0] MeM [9:0];

//Inicializacion 

initial 

    begin

        MeM [0] = 32'd 255;
        MeM [1] = 32'd 127;
        MeM [2] = 32'd 63;
        MeM [3] = 32'd 31;
        MeM [4] = 32'd 15;
    
    end

//Lectura
 always @*
    begin
        if(EN)
            begin
                MeM[Dir]=DatoE;
            end
        else
            begin
                Datos=MeM[Dir];
            end
        
  

    end

endmodule
